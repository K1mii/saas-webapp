# =========================
# Terraform
# =========================

# Downloaded provider plugins — regenerated by terraform init
.terraform/

# Local state files — real state lives in S3
*.tfstate
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform plan output files (contain sensitive data)
*.tfplan

# Override files (local developer overrides, not for sharing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =========================
# Docker
# =========================

# Ignore any local .env files used for docker-compose or local testing
.env
.env.*

# =========================
# OS / Editor
# =========================

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# VS Code
.vscode/

# JetBrains
.idea/

# =========================
# Node.js (app/)
# =========================

# Installed dependencies — restored by npm install
node_modules/

# npm debug logs
npm-debug.log*

# =========================
# DO NOT IGNORE
# =========================
# .terraform.lock.hcl   → commit this — locks provider versions across all runs
# terraform/modules/    → commit this — your actual infrastructure code
# .github/workflows/    → commit this — GitHub Actions needs this to run